# === API URLs (Points to Caddy gateway on port 8081) ===
SUPABASE_URL="http://localhost:8081"
VITE_SUPABASE_URL="http://localhost:8081"

# === Credentials (Dummy placeholders for self-hosted setup — NOT real Supabase keys) ===
# Auth is handled by Keycloak. These are only needed as non-empty strings for SDK init.
SUPABASE_PROJECT_ID="local"
VITE_SUPABASE_PROJECT_ID="local"
SUPABASE_PUBLISHABLE_KEY="local-anon-key-placeholder-not-a-real-secret"
VITE_SUPABASE_PUBLISHABLE_KEY="local-anon-key-placeholder-not-a-real-secret"
SUPABASE_SERVICE_ROLE_KEY="local-service-role-placeholder-not-a-real-secret"

# === Database ===
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/postgres"

# === Self-Hosted / Keycloak Config ===
BACKEND_MODE="self"
KEYCLOAK_INTERNAL_URL="http://localhost:8082"

