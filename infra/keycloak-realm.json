{
  "id": "lovable",
  "realm": "lovable",
  "enabled": true,
  "registrationAllowed": true,
  "roles": {
    "realm": [
      {
        "name": "admin",
        "description": "Administrator Role"
      },
      {
        "name": "manager",
        "description": "Manager Role"
      },
      {
        "name": "member",
        "description": "Regular Member Role"
      }
    ]
  },
  "users": [
    {
      "username": "admin@example.com",
      "enabled": true,
      "email": "admin@example.com",
      "emailVerified": true,
      "firstName": "Admin",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "admin123",
          "temporary": false
        }
      ],
      "realmRoles": [
        "admin",
        "manager",
        "member"
      ]
    },
    {
      "username": "manager@example.com",
      "enabled": true,
      "email": "manager@example.com",
      "emailVerified": true,
      "firstName": "Manager",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "manager123",
          "temporary": false
        }
      ],
      "realmRoles": [
        "manager",
        "member"
      ]
    },
    {
      "username": "member@example.com",
      "enabled": true,
      "email": "member@example.com",
      "emailVerified": true,
      "firstName": "Member",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "member123",
          "temporary": false
        }
      ],
      "realmRoles": [
        "member"
      ]
    }
  ],
  "clients": [
    {
      "clientId": "execution-os",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "redirectUris": [
        "http://localhost:8080/*",
        "http://localhost:8081/*",
        "http://localhost:8082/*"
      ],
      "webOrigins": [
        "http://localhost:8080",
        "http://localhost:8081",
        "http://localhost:8082",
        "*"
      ],
      "protocol": "openid-connect",
      "fullScopeAllowed": true,
      "protocolMappers": [
        {
          "name": "role-hardcoded",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-hardcoded-claim-mapper",
          "consentRequired": false,
          "config": {
            "claim.name": "role",
            "claim.value": "authenticated",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ]
}
