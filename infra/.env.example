# Copy to .env on the VM and fill in.

# === Postgres ===
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_strong
POSTGRES_DB=app

# === JWT — MUST be identical for GoTrue + PostgREST ===
# Generate with: openssl rand -base64 48
BACKEND_JWT_SECRET=change_me_64_chars_base64

# === GoTrue ===
GOTRUE_SITE_URL=https://app.example.com
GOTRUE_URI_ALLOW_LIST=https://app.example.com
GOTRUE_MAILER_AUTOCONFIRM=false
GOTRUE_DISABLE_SIGNUP=false
GOTRUE_EXTERNAL_GOOGLE_ENABLED=true
GOTRUE_EXTERNAL_GOOGLE_CLIENT_ID=
GOTRUE_EXTERNAL_GOOGLE_SECRET=
GOTRUE_EXTERNAL_GOOGLE_REDIRECT_URI=https://auth.example.com/callback
GOTRUE_SMTP_HOST=
GOTRUE_SMTP_PORT=587
GOTRUE_SMTP_USER=
GOTRUE_SMTP_PASS=
GOTRUE_SMTP_ADMIN_EMAIL=

# === MinIO ===
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_strong
MINIO_BUCKET=work-item-files

# === Public hostnames (used by Caddy) ===
API_DOMAIN=api.example.com
AUTH_DOMAIN=auth.example.com
FILES_DOMAIN=files.example.com

# === Source (Supabase) — for export/cutover scripts only ===
SUPABASE_PROJECT_REF=
SUPABASE_DB_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_URL=
